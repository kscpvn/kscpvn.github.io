rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Roster thành viên (email + vai trò) — dùng để phân quyền phía máy chủ.
    // Nếu chưa có doc _members thì dùng danh sách khởi tạo mặc định bên dưới.
    function roster() {
      return exists(/databases/$(database)/documents/kscp/_members)
        ? get(/databases/$(database)/documents/kscp/_members).data
        : {
            adminEmails: ['vuongnb@klbgroup.vn', 'minhvuongktxd@gmail.com'],
            memberEmails: ['mydh@klbgroup.vn', 'tuannn@klbgroup.vn', 'diendp@klbgroup.vn', 'bacbc@klbgroup.vn']
          };
    }
    function userEmail() {
      return request.auth != null ? request.auth.token.email : '';
    }
    // Admin gốc luôn có quyền (dự phòng, để khởi tạo/khôi phục roster khi cần)
    function isAdmin() {
      return request.auth != null &&
        (userEmail() == 'vuongnb@klbgroup.vn' || userEmail() == 'minhvuongktxd@gmail.com'
          || userEmail() in roster().get('adminEmails', []));
    }
    function isEditor() {
      return request.auth != null &&
        (isAdmin() || userEmail() in roster().get('memberEmails', []));
    }

    // Doc roster: ai cũng ĐỌC được (client cần biết vai trò để hiện đúng nút),
    // chỉ Admin được GHI (duyệt/thêm/bớt thành viên).
    match /kscp/_members {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Dữ liệu dùng chung: AI CÓ LINK CŨNG ĐỌC ĐƯỢC (view-only),
    // chỉ Thành viên/Admin đã đăng nhập mới GHI.
    match /kscp/{docId} {
      allow read: if true;
      allow write: if docId != '_members' && isEditor();
    }
  }
}
